{
  "trailingSlash": false,
  "ignoreCommand": "[ \"$VERCEL_GIT_COMMIT_REF\" != \"main\" ]",
  "rewrites": [
    { "source": "/SamStudio/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/SamStudio/samples/:path*", "destination": "/samples/:path*" },
    { "source": "/SamStudio/:file([^/]+\\.[^/]+)", "destination": "/:file" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
